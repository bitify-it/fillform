# Copy to .env and adjust. All variables are optional; defaults are shown.

APP_ENV=development
LOG_LEVEL=INFO

# Upload / storage
MAX_UPLOAD_BYTES=26214400
STORAGE_DIR=storage

# LLM provider: ollama | openai | vllm | lmstudio | together | groq | anthropic | claude
LLM_PROVIDER=ollama
LLM_MODEL=gemma2:9b
LLM_ENDPOINT=http://localhost:11434
LLM_API_KEY=
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=120
LLM_JSON_REPAIR_ATTEMPTS=2

# Ollama only: forces the context window (raise for larger documents).
LLM_NUM_CTX=16384

# Anthropic only: max tokens in the response.
LLM_MAX_TOKENS=4096

# Double-check: low_confidence | answered | always | disabled
DOUBLE_CHECK_MODE=low_confidence
DOUBLE_CHECK_CONFIDENCE_THRESHOLD=0.6
